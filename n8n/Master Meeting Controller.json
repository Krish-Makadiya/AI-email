      "id": "8fe536bc-0444-4842-8c50-6a919aaeb6b1",
      "name": "Create Google Event",
      "credentials": {
        "googleCalendarOAuth2Api": {
          "id": "86S7RvqQKlVN61Jw",
          "name": "Google Calendar account"
        }
