    {
      "parameters": {
        "jsCode": "// 1. Pull the data from the initial Webhook trigger\nconst body = $('Webhook').item.json.body;\n\n// 2. Create the Start and End Date objects (defaulting to 30-minute meetings)\nconst start = new Date(body.start_time);\nconst end = new Date(start.getTime() + 30 * 60000); \n\n// 3. Helper function to ensure format is ALWAYS 'YYYY-MM-DDTHH:mm:ssZ'\n// This strips the '.000' milliseconds that often trigger the 400 Bad Request.\nconst formatForGoogle = (date) => date.toISOString().split('.')[0] + \"Z\";\n\nreturn {\n  start: formatForGoogle(start),\n  end: formatForGoogle(end),\n  attendee: body.recipient || body.mail?.sender_mail || \"guest@example.com\",\n  summary: `Meeting with ${body.recipient || 'Guest'}`\n};"
      },
